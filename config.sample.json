{
  "schema": "strata/config",
  "version": 1,
  "mirakurun": {
    "url": "http://127.0.0.1:40772",
    "recordingPriority": 2,
    "conflictedPriority": 1
  },
  "recording": {
    "directory": "./recorded/",
    "filenameFormat": "[<date:yymmdd-HHMM>][<type><channel>][<channel-name>]<title>.m2ts",
    "lowSpace": {
      "thresholdMB": 3000,
      "action": "remove"
    }
  },
  "web": {
    "listenAddress": "127.0.0.1",
    "port": 20772,
    "authentication": {
      "enabled": false
    }
  },
  "wuiWebDir": "",
  "previewCache": {
    "maxAgeDays": 30,
    "maxSizeMB": 1024
  },
  "services": {
    "excluded": [],
    "order": []
  },
  "advanced": {
    "normalizationForm": "NFKC"
  }
}
